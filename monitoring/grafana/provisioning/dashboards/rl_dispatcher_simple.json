{
  "title": "RL Dispatcher — Cluster Monitor",
  "uid": "rl-dispatcher-simple",
  "schemaVersion": 38,
  "refresh": "5s",
  "time": { "from": "now-5m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "CPU Usage % per Node",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 9 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0, "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 60, "color": "yellow" },
              { "value": 85, "color": "red" }
            ]
          }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] }
      },
      "targets": [
        {
          "expr": "100 * (1 - avg by(node) (rate(node_cpu_seconds_total{mode=\"idle\"}[1m])))",
          "legendFormat": "{{node}}",
          "datasource": { "type": "prometheus", "uid": "Prometheus" }
        }
      ],
      "datasource": { "type": "prometheus", "uid": "Prometheus" }
    },
    {
      "id": 2,
      "title": "Memory Usage % per Node",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 9, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": { "unit": "percent", "min": 0, "max": 100 }
      },
      "targets": [
        {
          "expr": "100 * (1 - node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)",
          "legendFormat": "{{node}}",
          "datasource": { "type": "prometheus", "uid": "Prometheus" }
        }
      ],
      "datasource": { "type": "prometheus", "uid": "Prometheus" }
    },
    {
      "id": 3,
      "title": "Network I/O (bytes/s)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 9, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "Bps" } },
      "targets": [
        {
          "expr": "rate(node_network_receive_bytes_total{device!~\"lo|docker.*|veth.*\"}[1m])",
          "legendFormat": "{{node}} RX {{device}}",
          "datasource": { "type": "prometheus", "uid": "Prometheus" }
        },
        {
          "expr": "rate(node_network_transmit_bytes_total{device!~\"lo|docker.*|veth.*\"}[1m])",
          "legendFormat": "{{node}} TX {{device}}",
          "datasource": { "type": "prometheus", "uid": "Prometheus" }
        }
      ],
      "datasource": { "type": "prometheus", "uid": "Prometheus" }
    },
    {
      "id": 4,
      "title": "Node Status (Up=1 / Down=0)",
      "type": "stat",
      "gridPos": { "x": 0, "y": 17, "w": 12, "h": 5 },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" } } },
            { "type": "value", "options": { "1": { "text": "UP", "color": "green" } } }
          ]
        }
      },
      "targets": [
        {
          "expr": "up{job=~\"edge_1|edge_2|cloud\"}",
          "legendFormat": "{{node}}",
          "datasource": { "type": "prometheus", "uid": "Prometheus" }
        }
      ],
      "datasource": { "type": "prometheus", "uid": "Prometheus" }
    },
    {
      "id": 5,
      "title": "Load Average (1m)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 17, "w": 12, "h": 5 },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        {
          "expr": "node_load1",
          "legendFormat": "{{node}}",
          "datasource": { "type": "prometheus", "uid": "Prometheus" }
        }
      ],
      "datasource": { "type": "prometheus", "uid": "Prometheus" }
    }
  ],
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "tags": ["rl", "edge-cloud"],
  "version": 1
}
